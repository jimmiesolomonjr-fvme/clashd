# =============================================================================
# Clashd Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it's in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# Local dev: run `supabase start` and use the local values printed to console.

# Public URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Agora (Video/Audio RTC)
# -----------------------------------------------------------------------------
# Get these from: https://console.agora.io → Project Management → Config
# You need a project with "Secured mode" (APP ID + Token).

# App ID — used client-side to join channels
NEXT_PUBLIC_AGORA_APP_ID=your-agora-app-id

# App Certificate — server-side only, used to generate RTC tokens
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# -----------------------------------------------------------------------------
# Expo / React Native (same values, different prefix)
# -----------------------------------------------------------------------------
# These are consumed by the mobile app via Expo's env var system.

EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_AGORA_APP_ID=your-agora-app-id

# =============================================================================
# Production Supabase Setup
# =============================================================================
#
# 1. Create a project at https://supabase.com/dashboard
# 2. Install Supabase CLI: npx supabase login
# 3. Link your project: npx supabase link --project-ref <your-project-ref>
# 4. Push migrations: npx supabase db push
# 5. Deploy Edge Functions: npx supabase functions deploy
# 6. Go to Authentication → URL Configuration:
#    - Set Site URL to your production domain (e.g. https://clashd.tv)
#    - Add redirect URLs: https://clashd.tv/auth/callback
# 7. (Optional) Enable OAuth providers under Authentication → Providers:
#    - Google: add Client ID + Secret from Google Cloud Console
#    - Apple: add Service ID + Key from Apple Developer Portal
# 8. Copy your project URL + anon key + service role key into your
#    Vercel environment variables (or .env.local for local dev).
#
# =============================================================================
